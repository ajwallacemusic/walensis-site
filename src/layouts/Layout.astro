---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Deal Lens is the deal checker for enthusiast gear — music, cameras, golf. AI analysis for Facebook Marketplace, eBay, and Reverb listings.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-logo">Walensis</a>
        <nav class="site-nav">
          <a href="https://chromewebstore.google.com/detail/deal-lens/ndojllleemkjjelapmjdgapoeincbiol" class="nav-cta">Get Deal Lens</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/support">Support</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-links">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/support">Support</a>
      </div>
      <div>&copy; {new Date().getFullYear()} Walensis. All rights reserved.</div>
    </footer>
  </body>
</html>
