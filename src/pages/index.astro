---
import Layout from '../layouts/Layout.astro';

// TODO: replace with Chrome Web Store listing URL once Deal Lens is published.
const chromeWebStoreUrl = '#';
---

<Layout
  title="Deal Lens — Know what it's worth"
  description="Deal Lens is a Chrome extension that analyzes resale listings on Facebook Marketplace, eBay, and Reverb to estimate fair market value and spot real deals."
>
  <section class="hero">
    <h1>Deal Lens</h1>
    <p>
      Know what it's worth. Deal Lens analyzes resale listings on Facebook
      Marketplace, eBay, and Reverb so you can spot fair prices and find real
      deals — instantly, in your browser.
    </p>
    <a href={chromeWebStoreUrl} class="btn">Get Deal Lens for Chrome</a>
    <p class="muted" style="margin-top: 1.25rem;">A Walensis product.</p>
  </section>

  <section class="features">
    <div class="feature">
      <h3>Instant fair-market estimates</h3>
      <p>
        See an estimated value the moment you open a listing. No spreadsheets,
        no tab-juggling, no guessing.
      </p>
    </div>
    <div class="feature">
      <h3>Comparable sold listings</h3>
      <p>
        Pulls real comps from eBay and Reverb so you can verify the estimate
        against actual market data.
      </p>
    </div>
    <div class="feature">
      <h3>Buy or flip analysis</h3>
      <p>
        Tells you whether something is a good buy at the asking price — and whether
        it's worth flipping for profit.
      </p>
    </div>
    <div class="feature">
      <h3>Works where you shop</h3>
      <p>
        Facebook Marketplace, eBay, and Reverb supported today. More platforms coming.
      </p>
    </div>
  </section>
</Layout>
