---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Welcome to Enthusiast — Deal Lens">
  <div class="welcome">
    <h1>You're in.</h1>
    <p>
      Your Enthusiast subscription is active. You now have access to comparable
      sales, flip margins, and similar listings on every analysis.
    </p>
    <p>
      Head back to the tab where you were browsing and check the price on your
      next find. Deal Lens will pick up your new tier automatically.
    </p>
    <p class="muted">
      You can manage your subscription anytime from the Deal Lens panel — look
      for "Manage subscription" after running an analysis.
    </p>
  </div>
</Layout>

<style>
  .welcome {
    text-align: center;
    padding-top: 2rem;
  }
  .welcome h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .welcome p {
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
